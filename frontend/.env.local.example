# Server-side FastAPI backend URL. When set, the /api/spots route handlers proxy
# the live wall data; when unset (or unreachable) they fall back to the static
# dummy GeoJSON in public/data. Not NEXT_PUBLIC_ — only used in route handlers.
# BACKEND_URL=http://localhost:8000

# Optional: set to live FastAPI URL when pipeline is ready
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional MapTiler key (using free CARTO style by default)
# NEXT_PUBLIC_MAPTILER_KEY=
